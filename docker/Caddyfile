# Reverse proxy with auto-HTTPS (Let's Encrypt) for app.workenai.com
# and api.workenai.com.
#
# First deploy must be done with Cloudflare set to DNS-only (grey cloud)
# so the HTTP-01 challenge can reach Caddy directly. After Caddy has
# obtained certs, you can flip the proxy on (orange cloud) and set
# SSL/TLS mode to Full (strict) in Cloudflare.
#
# Note: SSE streaming + gzip can introduce minor buffering. Caddy does
# not let us exclude a response by Content-Type in `encode`, so for
# token-by-token chat streaming the API should set
# `X-Accel-Buffering: no` on SSE responses (cleaner than a Caddy hack).

{
}

app.workenai.com {
    encode zstd gzip
    reverse_proxy web:3000
}

api.workenai.com {
    encode zstd gzip
    reverse_proxy api:3001
}
