# Copy to .env and fill in real values. Do NOT commit .env.

# Database — PostgreSQL with pgvector. Defaults match `pnpm db:start`.
DATABASE_URL=postgresql://worken:worken@localhost:5432/worken

# Redis — used for refresh-token storage and auth rate-limit counters.
REDIS_URL=redis://localhost:6379

# ┌──────────────────────────────────────────────────────────────────┐
# │ Auth rate limiting (issue #23) + reverse-proxy trust              │
# ├──────────────────────────────────────────────────────────────────┤
# │ Protects /auth/login, /auth/signup, /auth/resend-verification    │
# │ and /auth/forgot-password against brute force + mail spam.        │
# │ Counters live in Redis. All limits below are OPTIONAL — the       │
# │ defaults (shown) apply when unset. ttls are in SECONDS.           │
# └──────────────────────────────────────────────────────────────────┘
#
# Number of reverse-proxy hops in front of the API, so `req.ip` (used as
# the per-IP rate-limit key) resolves to the real client. Production is
# Cloudflare → Caddy → api = 2. Set to 0 for local dev (no proxy).
TRUST_PROXY_HOPS=0
#
# Dev-only kill switch. `true` disables all auth rate limiting — IGNORED
# when NODE_ENV=production, so it can never silently drop protection in
# prod. Default OFF.
RATE_LIMIT_DISABLED=false
#
# Temporary debug: `true` logs X-Forwarded-For / CF-Connecting-IP /
# resolved req.ip for every request. Flip on in prod for one request to
# confirm TRUST_PROXY_HOPS, then turn back off.
LOG_PROXY_IP=false
#
# Per-endpoint limits (limit = requests, ttl = window in seconds).
# RL_LOGIN_IP_LIMIT=5            RL_LOGIN_IP_TTL=60
# RL_LOGIN_EMAIL_LIMIT=10        RL_LOGIN_EMAIL_TTL=3600
# RL_SIGNUP_IP_MIN_LIMIT=3       RL_SIGNUP_IP_MIN_TTL=60
# RL_SIGNUP_IP_DAY_LIMIT=20      RL_SIGNUP_IP_DAY_TTL=86400
# RL_RESEND_EMAIL_LIMIT=3        RL_RESEND_EMAIL_TTL=3600
# RL_RESEND_IP_LIMIT=10          RL_RESEND_IP_TTL=3600
# RL_FORGOT_EMAIL_LIMIT=3        RL_FORGOT_EMAIL_TTL=3600
# RL_FORGOT_IP_LIMIT=10          RL_FORGOT_IP_TTL=3600

# Public origin of the web app. Used by the API to build links (e.g. verify
# email links in outgoing mails) and by OAuth callbacks to bounce the user
# back to the right environment.
#
# IMPORTANT for production: branded outgoing emails (verification,
# password reset, org invitation) embed `${FRONTEND_URL}/full-logo.png`
# as the brand image. Email clients fetch this URL from the recipient's
# device — it MUST be a publicly reachable URL, not an internal
# hostname like `http://web:3000` or a docker-internal address. If the
# image fails to load the email still renders, but the brand wordmark
# is missing.
FRONTEND_URL=http://localhost:3000

# Public origin of the API itself. Used inside emails to construct links to
# /auth/verify?token=… and similar API-served routes. Must be the URL the
# end user's browser can hit — not an internal hostname.
API_URL=http://localhost:3001

# OpenRouter provisioning + encryption key for per-team API keys.
OPENROUTER_PROVISIONING_KEY=
OPENROUTER_ENCRYPTION_KEY=

# ┌──────────────────────────────────────────────────────────────────┐
# │ Google OAuth — sign-in + Drive integration (Knowledge Core)      │
# ├──────────────────────────────────────────────────────────────────┤
# │ ONE-TIME SETUP (per environment):                                │
# │   1. Google Cloud Console → APIs & Services → Credentials → new  │
# │      OAuth 2.0 Client ID ("Web application").                    │
# │   2. Under "Authorized redirect URIs", register BOTH:             │
# │        http://localhost:3001/auth/google/callback                 │
# │        http://localhost:3001/google-drive/callback                │
# │      (Add the prod equivalents alongside before you deploy.)     │
# │   3. APIs & Services → OAuth consent screen → Scopes → add        │
# │        https://www.googleapis.com/auth/drive.readonly             │
# │      (Sensitive scope — required for Knowledge Core's Drive       │
# │      import. Userinfo/email is requested in the Drive flow too    │
# │      but lives under "Your non-sensitive scopes" already.)        │
# │   4. While in "Testing" mode, add yourself under "Test users" or  │
# │      Google blocks the consent screen with "Access blocked".     │
# │   5. Paste the Client ID + Client Secret below.                  │
# │                                                                  │
# │ Full walkthrough with screenshots: docs/google-drive-setup.md    │
# │ Health check after setup: pnpm setup:drive                        │
# └──────────────────────────────────────────────────────────────────┘
GOOGLE_CLIENT_ID=                # ends in ".apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET=            # starts with "GOCSPX-"
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3001/google-drive/callback

# ┌──────────────────────────────────────────────────────────────────┐
# │ Microsoft / SharePoint — Knowledge Core integration              │
# ├──────────────────────────────────────────────────────────────────┤
# │ ONE-TIME SETUP (per environment):                                │
# │   1. Azure portal → Microsoft Entra ID → App registrations →     │
# │      New registration ("Web", single- or multi-tenant).          │
# │   2. Add redirect URI (Web platform):                            │
# │        http://localhost:3001/sharepoint/callback                 │
# │      (Add the prod equivalent alongside before you deploy.)      │
# │   3. API permissions → Add → Microsoft Graph → Delegated:        │
# │        Files.Read.All                                            │
# │        Sites.Read.All                                            │
# │        User.Read                                                 │
# │        offline_access                                            │
# │      Sites.Read.All needs ADMIN CONSENT in most tenants — click  │
# │      "Grant admin consent for {tenant}" or ask your tenant       │
# │      admin (not required for personal Microsoft accounts).       │
# │   4. Certificates & secrets → New client secret → copy the       │
# │      VALUE (not Secret ID) within 10 minutes — Azure hides it    │
# │      after that.                                                 │
# │   5. Paste IDs below.                                            │
# │                                                                  │
# │ MICROSOFT_TENANT_ID notes:                                       │
# │   - `common`        = multi-tenant (work, school + personal MS). │
# │   - `organizations` = work + school only (no personal MS).       │
# │   - `<tenant GUID>` = single-tenant; required if your tenant     │
# │     blocks `common` via Conditional Access.                      │
# │                                                                  │
# │ Full walkthrough: docs/sharepoint-setup.md                       │
# │ Health check after setup: pnpm setup:sharepoint                  │
# └──────────────────────────────────────────────────────────────────┘
MICROSOFT_CLIENT_ID=             # Azure "Application (client) ID" (GUID)
MICROSOFT_CLIENT_SECRET=         # Azure client secret VALUE (not Secret ID)
MICROSOFT_TENANT_ID=common       # `common` | `organizations` | tenant GUID
SHAREPOINT_REDIRECT_URI=http://localhost:3001/sharepoint/callback
# OneDrive shares the SAME Azure App registration as SharePoint —
# the only thing it needs additionally is a SECOND registered
# redirect URI in the Web platform configuration in Azure.
ONEDRIVE_REDIRECT_URI=http://localhost:3001/onedrive/callback

# ┌──────────────────────────────────────────────────────────────────┐
# │ Confluence (Atlassian) — Knowledge Core integration              │
# ├──────────────────────────────────────────────────────────────────┤
# │ ONE-TIME SETUP (per environment):                                │
# │   1. https://developer.atlassian.com/console → Create →          │
# │      "OAuth 2.0 integration".                                     │
# │   2. Permissions → add the Confluence API, then add scopes:      │
# │        read:confluence-space.summary                            │
# │        read:confluence-content.all                              │
# │        read:confluence-content.summary                          │
# │      (offline_access is added automatically by the connect flow  │
# │      so Atlassian returns a refresh token. Do NOT request a      │
# │      scope the app lacks — Atlassian's consent then fails with   │
# │      "Something went wrong".)                                    │
# │      Optional: to show the connected account's email, also add   │
# │      the User Identity API with read:me.                         │
# │   3. Authorization → Add "OAuth 2.0 (3LO)" → set Callback URL:   │
# │        http://localhost:3001/confluence/callback                 │
# │      (Add the prod equivalent alongside before you deploy.)      │
# │   4. Settings → copy the Client ID + Secret below.               │
# │                                                                  │
# │ Full walkthrough: docs/confluence-setup.md                       │
# └──────────────────────────────────────────────────────────────────┘
CONFLUENCE_CLIENT_ID=            # Atlassian "Client ID"
CONFLUENCE_CLIENT_SECRET=        # Atlassian "Secret"
CONFLUENCE_REDIRECT_URI=http://localhost:3001/confluence/callback

# JWT — used for access / refresh tokens. Generate with e.g. `openssl rand -hex 64`.
JWT_SECRET=
JWT_REFRESH_SECRET=

# SMTP — required for invite emails and email-verification links. Without
# these the signup still returns 200, but users will never receive the link
# and will have to hit "Resend" on /check-email.
MAIL_HOST=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@workenai.local

# Optional — when set, the "Follow Us" footer at the bottom of branded
# emails (verification / password reset / org invitation) renders with
# linked LinkedIn / Twitter labels. Leave both blank to omit the footer
# entirely (recommended until we have real social accounts wired up).
LINKEDIN_URL=
TWITTER_URL=
