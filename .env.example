# Copy to .env and fill in real values. Do NOT commit .env.

# Database — PostgreSQL with pgvector. Defaults match `pnpm db:start`.
DATABASE_URL=postgresql://worken:worken@localhost:5432/worken

# Redis — used for refresh-token storage.
REDIS_URL=redis://localhost:6379

# Public origin of the web app. Used by the API to build links (e.g. verify
# email links in outgoing mails) and by OAuth callbacks to bounce the user
# back to the right environment.
FRONTEND_URL=http://localhost:3000

# Public origin of the API itself. Used inside emails to construct links to
# /auth/verify?token=… and similar API-served routes. Must be the URL the
# end user's browser can hit — not an internal hostname.
API_URL=http://localhost:3001

# OpenRouter provisioning + encryption key for per-team API keys.
OPENROUTER_PROVISIONING_KEY=
OPENROUTER_ENCRYPTION_KEY=

# Auth — Google OAuth (other methods coming later).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT — used for access / refresh tokens. Generate with e.g. `openssl rand -hex 64`.
JWT_SECRET=
JWT_REFRESH_SECRET=

# SMTP — required for invite emails and email-verification links. Without
# these the signup still returns 200, but users will never receive the link
# and will have to hit "Resend" on /check-email.
MAIL_HOST=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@workenai.local
